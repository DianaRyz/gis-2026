{
  "version": 8,
  "name": "overture",
  "sources": {
    "overture": {
      "type": "geojson",
      "data": "overture.geojson"
    }
  },
  "layers": [
    {
      "id": "overture-fill",
      "type": "fill",
      "source": "overture",
      "paint": {
        "fill-color": [
          "match",
          ["get", "source_type"],
          "my", "#2ecc71",
          "osm", "#3498db",
          "ml", "#e67e22",
          "#888888"
        ],
        "fill-opacity": 0.7,
        "fill-outline-color": "#222222"
      }
    }
  ]
}
